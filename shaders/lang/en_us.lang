# ====================== GLOBAL ======================
option.GLOBAL_INTENSITY=Master-Mix
option.GLOBAL_INTENSITY.comment=Mixes the original image with the effect. §a0%§r = original only. §c100%§r = full effect strength. Works like a Photoshop layer opacity.

option.COMPARISON_MODE=Comparison Mode
value.COMPARISON_MODE.0=§7Aus
value.COMPARISON_MODE.1=§eSplit Vertical
value.COMPARISON_MODE.2=§eSplit Horizontal
value.COMPARISON_MODE.3=§dTime Toggle (3s)
option.COMPARISON_MODE.comment=A/B comparison. §eSplit§r: screen split with orange line. §dZeit-Toggle§r: alternates every 3s, green/red status dot top right.


# ====================== SYMPTOM-MASTER (Hauptmenü) ======================
option.STATIC_STRENGTH=§b§lStatic Strength
option.STATIC_STRENGTH.comment=Master slider for the visual snow grain (core symptom). §a0%§r = off, §c100%§r = full realistic effect. §e[i]§r Recommended range: 30–60%.

option.FLOATERS_STRENGTH=§7§lFloater Strength
option.FLOATERS_STRENGTH.comment=Master slider for floaters (vitreous opacities). §e[i]§r At 20–40% you see 1-3 floating shadows.

option.PALINOPSIA_STRENGTH=§d§lPalinopsia Strength
option.PALINOPSIA_STRENGTH.comment=Master slider for afterimages/trailing. Visible during camera motion. §c[!]§r At high values with static camera the image can "burn in".

option.PHOTOPHOBIA_STRENGTH=§e§lPhotophobia Strength
option.PHOTOPHOBIA_STRENGTH.comment=Master slider for light sensitivity. Bloom + exposure overshoot in bright areas. §c[!]§r Visibly brightens light surfaces like sky.

option.NYKTALOPIA_STRENGTH=§9§lNyctalopia Strength
option.NYKTALOPIA_STRENGTH.comment=Master slider for impaired night vision. Reduces saturation and brightness in dark scenes. Invisible during daytime.

option.BLUE_FIELD_STRENGTH=§b§lBlue Field Strength
option.BLUE_FIELD_STRENGTH.comment=Master slider for BFEP (Blue Field Entoptic Phenomenon). Bright dots over homogeneous blue surfaces. §c[!]§r Most visible on sky — can dominate the image there.

option.SELF_LIGHT_STRENGTH=§d§lSelf-light Strength
option.SELF_LIGHT_STRENGTH.comment=Master slider for self-light. Colored morphing clouds in deep darkness. Invisible during daytime.

option.ENABLE_BLUE_AGGRAVATION=Blue Light Trigger
value.ENABLE_BLUE_AGGRAVATION.0=§cAUS
value.ENABLE_BLUE_AGGRAVATION.1=§aAN
option.ENABLE_BLUE_AGGRAVATION.comment=§c[!]§r Clinically established (Hepschke et al. 2021): blue cone activation aggravates VSS. Multiplies static in blue image regions.

option.BLUE_AGGRAVATION_STRENGTH=Trigger Factor
suffix.BLUE_AGGRAVATION_STRENGTH= ×


